{
  "name": "financeos",
  "version": "0.1.0",
  "description": "Open-source finance operating system with API and web dashboard",
  "main": "server.js",
  "type": "commonjs",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "financeos-ui"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "start:api": "node server.js",
    "dev": "nodemon server.js",
    "dev:api": "nodemon server.js",
    "dev:web": "npm --prefix financeos-ui run dev",
    "build:web": "npm --prefix financeos-ui run build",
    "preview:web": "npm --prefix financeos-ui run preview",
    "db:clean:transactions": "node scripts/clean-transactions.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:api": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "mongoose": "^8.6.3",
    "multer": "^2.0.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
